rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['email', 'createdAt']) &&
        request.resource.data.keys().size() <= 10; // Limit document size
    }
    
    // Game scores - readable by all, writable by authenticated users
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['userId', 'gameId', 'score', 'timestamp']) &&
        request.resource.data.score is number &&
        request.resource.data.score >= 0 &&
        request.resource.data.timestamp is timestamp;
      allow update, delete: if false; // Scores are immutable
    }
    
    // Game statistics - readable by all, writable only by system
    match /stats/{statId} {
      allow read: if true;
      allow write: if false; // Only system can write stats
    }
    
    // Premium subscriptions - users can only read/write their own subscription data
    match /subscriptions/{subscriptionId} {
      allow read, write: if isOwner(subscriptionId);
      allow create: if isOwner(subscriptionId) &&
        request.resource.data.keys().hasAll(['userId', 'status', 'createdAt']) &&
        request.resource.data.status in ['active', 'canceled', 'past_due'];
    }
    
    // Game progress - users can only manage their own progress
    match /progress/{progressId} {
      allow read, write: if isOwner(progressId);
      allow create: if isOwner(progressId) &&
        request.resource.data.keys().hasAll(['userId', 'gameId', 'progress']) &&
        request.resource.data.gameId in ['guess', 'rps', 'memory'];
    }
    
    // Analytics events - writable by authenticated users, readable by system
    match /analytics/{eventId} {
      allow read: if false; // Analytics are private
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['userId', 'event', 'timestamp']) &&
        request.resource.data.event in ['game_play', 'page_view', 'premium_interaction'];
    }
    
    // Challenges - readable by all, creatable by authenticated users
    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if false;
    }
    
    // Challenge attempts - readable and creatable by all
    match /challengeAttempts/{attemptId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
    }
    
    // Deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
